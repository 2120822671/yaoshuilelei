<view class="page">
  <view class="header">
    <text class="page-title">设置</text>
  </view>

  <view class="settings-list">
    <view class="setting-item glass-card">
      <view class="setting-info">
        <text class="setting-icon">🌙</text>
        <text class="setting-text">夜间模式</text>
      </view>
      <switch 
        class="setting-switch" 
        checked="{{nightMode}}" 
        bindchange="toggleNightMode"
        color="#f5c66c"
      />
    </view>

    <view class="setting-item glass-card" bindtap="clearCache">
      <view class="setting-info">
        <text class="setting-icon">🗑️</text>
        <text class="setting-text">清除缓存</text>
      </view>
      <text class="setting-arrow">→</text>
    </view>

    <view class="setting-item glass-card" bindtap="showPrivacy">
      <view class="setting-info">
        <text class="setting-icon">🔒</text>
        <text class="setting-text">隐私政策</text>
      </view>
      <text class="setting-arrow">→</text>
    </view>

    <view class="setting-item glass-card" bindtap="showTerms">
      <view class="setting-info">
        <text class="setting-icon">📄</text>
        <text class="setting-text">用户协议</text>
      </view>
      <text class="setting-arrow">→</text>
    </view>
  </view>

  <view class="version-info">
    <text class="version-text">版本号 v1.0.0</text>
  </view>
</view>