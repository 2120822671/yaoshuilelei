.page {
  min-height: 100vh;
  padding: 32rpx;
  padding-bottom: 160rpx;
}

.user-section {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 60rpx;
  margin-bottom: 40rpx;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(245, 198, 108, 0.4), rgba(232, 168, 74, 0.2));
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(245, 198, 108, 0.5);
}

.avatar-icon {
  font-size: 64rpx;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.login-btn {
  padding: 16rpx 40rpx;
  background: linear-gradient(135deg, #ffd966, #f5c66c);
  border-radius: 100rpx;
  box-shadow: 0 8rpx 24rpx rgba(245, 198, 108, 0.3);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.login-text {
  font-size: 28rpx;
  color: #1a2744;
  font-weight: 600;
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.user-greeting {
  font-size: 28rpx;
  color: #f5c66c;
}

.stats-card {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 40rpx 32rpx;
  margin-bottom: 40rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #f5c66c;
}

.stat-label {
  font-size: 24rpx;
  color: #8b9bb4;
}

.stat-divider {
  width: 2rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.1);
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #f5c66c;
}

.collection-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.collection-card {
  padding: 28rpx;
}

.collection-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
}

.collection-intro {
  font-size: 26rpx;
  color: #8b9bb4;
  display: block;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.collection-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.meta-item {
  font-size: 22rpx;
  color: #5a6a7a;
}

.remove-btn {
  padding: 8rpx 20rpx;
  background: rgba(255, 100, 100, 0.1);
  border-radius: 100rpx;
}

.remove-text {
  font-size: 24rpx;
  color: #ff6464;
}

.empty-collection {
  padding: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.empty-icon {
  font-size: 64rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #5a6a7a;
}

.menu-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.menu-item {
  padding: 28rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.menu-icon {
  font-size: 36rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #fff;
}

.menu-arrow {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.3);
}

.upload-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 20rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.05);
}

.upload-item {
  width: calc(33.33% - 14rpx);
  border-radius: 16rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.05);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
  position: relative;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(255, 100, 100, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
}

.upload-img {
  width: 100%;
  height: 200rpx;
}

.upload-time {
  padding: 12rpx;
  font-size: 20rpx;
  color: #5a6a7a;
  text-align: center;
}

.upload-btn {
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.upload-icon {
  font-size: 40rpx;
}

.upload-text {
  font-size: 28rpx;
  color: #8b9bb4;
}

.footer {
  text-align: center;
  padding: 40rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #5a6a7a;
}