<view class="page">
  <view class="user-section">
    <view class="user-avatar" bindtap="handleAvatarTap">
      <image wx:if="{{userInfo}}" class="avatar-img" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
      <text wx:else class="avatar-icon">🌙</text>
    </view>
    <view class="user-info">
      <text class="user-name">{{userInfo ? userInfo.nickName : '点击登录'}}</text>
      <text class="user-greeting">{{greeting}}</text>
    </view>
    <view wx:if="{{!userInfo || !userInfo.nickName}}" class="login-btn" bindtap="handleLogin">
      <text class="login-text">登录</text>
    </view>
  </view>

  <view class="stats-card glass-card">
    <view class="stat-item">
      <text class="stat-value">{{accompanyDays}}</text>
      <text class="stat-label">陪伴天数</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">{{collectionCount}}</text>
      <text class="stat-label">我的收藏</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">0</text>
      <text class="stat-label">晚安计划</text>
    </view>
  </view>

  <view class="section">
    <text class="section-title">我的收藏</text>
    <view class="collection-list" wx:if="{{collections.length > 0}}">
      <view 
        class="collection-card glass-card" 
        wx:for="{{collections}}" 
        wx:key="id"
        bindtap="goToStoryDetail"
        data-id="{{item.id}}"
      >
        <text class="collection-title">{{item.title}}</text>
        <text class="collection-intro">{{item.intro}}</text>
        <view class="collection-meta">
          <text class="meta-item">⏱ {{item.duration}}</text>
          <view class="remove-btn" bindtap="removeCollection" data-id="{{item.id}}" catchtap="preventBubble">
            <text class="remove-text">移除</text>
          </view>
        </view>
      </view>
    </view>
    <view class="empty-collection glass-card" wx:else>
      <text class="empty-icon">📚</text>
      <text class="empty-text">还没有收藏任何故事</text>
    </view>
  </view>

  <view class="section" wx:if="{{uploadImages.length > 0}}">
    <text class="section-title">我的相册</text>
    <view class="upload-list">
      <view 
        class="upload-item" 
        wx:for="{{uploadImages}}" 
        wx:key="cloudPath"
      >
        <image class="upload-img" src="{{item.fileID}}" mode="aspectFill" />
        <view class="upload-time">{{item.uploadTime}}</view>
        <view 
          class="delete-btn" 
          bindtap="deleteImage" 
          data-fileid="{{item.fileID}}"
          data-cloudpath="{{item.cloudPath}}"
        >
          <text class="delete-icon">✕</text>
        </view>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{userInfo}}">
    <text class="section-title">上传图片</text>
    <view class="upload-btn glass-card" bindtap="chooseImage">
      <text class="upload-icon">📷</text>
      <text class="upload-text">点击上传图片到云存储</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item glass-card" bindtap="goToSettings">
      <view class="menu-icon">⚙️</view>
      <text class="menu-text">设置</text>
      <text class="menu-arrow">→</text>
    </view>
    <view class="menu-item glass-card" bindtap="showAbout">
      <view class="menu-icon">ℹ️</view>
      <text class="menu-text">关于我们</text>
      <text class="menu-arrow">→</text>
    </view>
  </view>

  <view class="footer">
    <text class="footer-text">要睡了嘞 v1.0.0</text>
  </view>
</view>