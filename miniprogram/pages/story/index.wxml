<view class="page">
  <view class="header">
    <text class="page-title">晚安故事</text>
    <text class="page-desc">在故事中进入甜美的梦乡</text>
  </view>

  <view class="story-list">
    <view 
      class="story-card glass-card" 
      wx:for="{{storyList}}" 
      wx:key="id" 
      bindtap="goToDetail"
      data-id="{{item.id}}"
    >
      <view class="story-cover">
        <text class="cover-icon">📖</text>
      </view>
      <view class="story-info">
        <text class="story-title">{{item.title}}</text>
        <text class="story-intro">{{item.intro}}</text>
        <view class="story-meta">
          <text class="meta-item">⏱ {{item.duration}}</text>
        </view>
      </view>
      <view class="story-action">
        <text class="action-icon">▶</text>
      </view>
    </view>
  </view>

  <view class="footer">
    <text class="footer-text">共 {{storyList.length}} 个故事</text>
  </view>
</view>