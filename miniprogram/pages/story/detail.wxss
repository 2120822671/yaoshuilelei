.page {
  min-height: 100vh;
  padding: 32rpx;
  padding-bottom: 240rpx;
}

.story-header {
  padding: 48rpx;
  margin-bottom: 32rpx;
  position: relative;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(245, 198, 108, 0.15), rgba(232, 168, 74, 0.08));
}

.header-content {
  position: relative;
  z-index: 1;
}

.story-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 20rpx;
}

.story-meta {
  display: flex;
  gap: 24rpx;
}

.meta-item {
  font-size: 28rpx;
  color: #f5c66c;
  padding: 8rpx 20rpx;
  background: rgba(245, 198, 108, 0.15);
  border-radius: 100rpx;
}

.player-section {
  padding: 40rpx;
  margin-bottom: 32rpx;
}

.player-display {
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.wave-animation {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.wave-bar {
  width: 12rpx;
  height: 80rpx;
  background: linear-gradient(180deg, #f5c66c, #e8a84a);
  border-radius: 6rpx;
  animation: wave 0.8s ease-in-out infinite;
}

@keyframes wave {
  0%, 100% { height: 40rpx; opacity: 0.6; }
  50% { height: 100rpx; opacity: 1; }
}

.player-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(245, 198, 108, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-text {
  font-size: 56rpx;
}

.progress-control {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.time-text {
  font-size: 26rpx;
  color: #8b9bb4;
  min-width: 100rpx;
}

.progress-bar-wrap {
  flex: 1;
}

.progress-bar {
  height: 12rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 6rpx;
  position: relative;
  overflow: visible;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #f5c66c, #e8a84a);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-thumb {
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 28rpx;
  height: 28rpx;
  background: #f5c66c;
  border-radius: 50%;
  box-shadow: 0 4rpx 12rpx rgba(245, 198, 108, 0.5);
  transition: left 0.3s ease;
}

.player-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 48rpx;
}

.control-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.control-btn.primary {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #f5c66c, #e8a84a);
  box-shadow: 0 8rpx 24rpx rgba(245, 198, 108, 0.4);
}

.control-btn.secondary {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.1);
}

.control-icon {
  font-size: 48rpx;
  color: #0a1628;
}

.control-btn.secondary .control-icon {
  font-size: 36rpx;
  color: #f5c66c;
}

.control-text {
  font-size: 28rpx;
  color: #f5c66c;
  font-weight: 600;
}

.story-content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.content-paragraph {
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  border-left: 6rpx solid rgba(245, 198, 108, 0.3);
}

.paragraph-text {
  font-size: 32rpx;
  color: #e0e6ed;
  line-height: 1.8;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.timer-section {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  background: rgba(245, 198, 108, 0.1);
  border-radius: 100rpx;
}

.timer-icon {
  font-size: 32rpx;
}

.timer-text {
  font-size: 28rpx;
  color: #f5c66c;
}

.action-section {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.action-icon {
  font-size: 40rpx;
}

.action-text {
  font-size: 22rpx;
  color: #8b9bb4;
}

.timer-modal,
.speed-modal,
.effects-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.timer-content,
.speed-content,
.effects-content {
  width: 100%;
  padding: 48rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  border-radius: 48rpx 48rpx 0 0;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  text-align: center;
  margin-bottom: 40rpx;
}

.timer-options,
.speed-options {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.timer-option,
.speed-option {
  flex: 1;
  min-width: calc(33.33% - 14rpx);
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  text-align: center;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.timer-option.selected,
.speed-option.selected {
  background: rgba(245, 198, 108, 0.2);
  border-color: #f5c66c;
}

.option-text {
  font-size: 30rpx;
  color: #fff;
}

.timer-option.selected .option-text,
.speed-option.selected .option-text {
  color: #f5c66c;
}

.effects-options {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.effect-option {
  flex: 1;
  min-width: calc(50% - 10rpx);
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  text-align: center;
  border: 2rpx solid transparent;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.effect-option.selected {
  background: rgba(245, 198, 108, 0.2);
  border-color: #f5c66c;
}

.effect-icon {
  font-size: 48rpx;
}

.effect-text {
  font-size: 28rpx;
  color: #fff;
}

.effect-option.selected .effect-text {
  color: #f5c66c;
}

.modal-close {
  padding: 28rpx;
  background: rgba(245, 198, 108, 0.2);
  border-radius: 20rpx;
  text-align: center;
  margin-top: 24rpx;
}

.close-text {
  font-size: 32rpx;
  color: #f5c66c;
  font-weight: 600;
}