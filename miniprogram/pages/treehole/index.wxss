.page {
  min-height: 100vh;
  padding: 32rpx;
  padding-bottom: 160rpx;
}

.header {
  margin-top: 40rpx;
  margin-bottom: 32rpx;
}

.page-title {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
}

.page-desc {
  font-size: 28rpx;
  color: #8b9bb4;
}

.intro-card {
  padding: 32rpx;
  margin-bottom: 32rpx;
  display: flex;
  gap: 20rpx;
}

.intro-icon {
  font-size: 48rpx;
  flex-shrink: 0;
}

.intro-text {
  font-size: 28rpx;
  color: #e0e6ed;
  line-height: 1.6;
}

.input-section {
  padding: 32rpx;
  margin-bottom: 40rpx;
}

.message-input {
  width: 100%;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 30rpx;
  color: #fff;
  margin-bottom: 24rpx;
}

.input-placeholder {
  color: #5a6a7a;
}

.input-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.char-count {
  font-size: 24rpx;
  color: #5a6a7a;
}

.publish-btn {
  padding: 20rpx 48rpx;
  font-size: 28rpx;
}

.messages-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 24rpx;
}

.messages-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.message-card {
  padding: 28rpx;
}

.message-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.avatar-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(245, 198, 108, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  font-size: 32rpx;
}

.message-time {
  font-size: 24rpx;
  color: #5a6a7a;
}

.message-content {
  font-size: 30rpx;
  color: #e0e6ed;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.message-footer {
  display: flex;
  justify-content: flex-end;
}

.like-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 100rpx;
}

.like-icon {
  font-size: 28rpx;
}

.like-count {
  font-size: 24rpx;
  color: #8b9bb4;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 80rpx;
}

.empty-icon {
  font-size: 64rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #5a6a7a;
}