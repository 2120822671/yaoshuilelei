.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #0a1628 0%, #1a237e 100%);
  padding: 30rpx;
}

.vote-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 30rpx;
}

.vote-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  flex: 1;
  line-height: 1.4;
}

.vote-status {
  margin-left: 20rpx;
}

.status {
  font-size: 26rpx;
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
}

.status.active {
  background: rgba(76, 175, 80, 0.3);
  color: #69f0ae;
}

.status.voted {
  background: rgba(156, 39, 176, 0.3);
  color: #ce93d8;
}

.vote-info {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 25rpx;
  margin-bottom: 30rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #8b9bb4;
}

.info-value {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
}

.options-section {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 25rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 25rpx;
  display: block;
}

.option-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 25rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.option-item:last-child {
  border-bottom: none;
}

.option-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.option-radio {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid #8b9bb4;
  border-radius: 50%;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.option-radio.selected {
  border-color: #f5c66c;
  background: rgba(245, 198, 108, 0.2);
}

.radio-inner {
  width: 24rpx;
  height: 24rpx;
  background: #f5c66c;
  border-radius: 50%;
}

.option-text {
  font-size: 30rpx;
  color: #fff;
}

.option-right {
  display: flex;
  align-items: center;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.progress-bar {
  width: 150rpx;
  height: 16rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 8rpx;
  overflow: hidden;
  margin-right: 15rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #f5c66c 0%, #ff9800 100%);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.vote-count {
  font-size: 24rpx;
  color: #f5c66c;
  min-width: 100rpx;
  text-align: right;
}

.submit-area {
  padding: 20rpx 0 40rpx;
}

.submit-btn {
  width: 100%;
  height: 90rpx;
  background: linear-gradient(135deg, #f5c66c 0%, #ff9800 100%);
  border-radius: 45rpx;
  color: #0a1628;
  font-size: 32rpx;
  font-weight: bold;
}

.result-hint {
  text-align: center;
  padding: 20rpx 0 40rpx;
}

.hint-text {
  font-size: 28rpx;
  color: #69f0ae;
}

.share-section {
  padding-top: 20rpx;
}

.share-btn {
  width: 100%;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid #8b9bb4;
  border-radius: 40rpx;
  color: #8b9bb4;
  font-size: 28rpx;
}