page {
  background: linear-gradient(180deg, #0a1628 0%, #0d1f35 40%, #132742 80%, #1a2f4a 100%);
  min-height: 100vh;
  color: #fff;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.glass-card {
  background: rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
  border-radius: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.glass-card:active {
  transform: scale(0.98);
  background: rgba(255, 255, 255, 0.08);
}

.primary-btn {
  background: linear-gradient(135deg, #f5c66c 0%, #e8a84a 100%);
  color: #0a1628;
  font-weight: 600;
  border-radius: 100rpx;
  padding: 24rpx 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(245, 198, 108, 0.4);
}

.primary-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(245, 198, 108, 0.3);
}

.accent-color {
  color: #f5c66c;
}

.text-muted {
  color: #8b9bb4;
}

.text-white {
  color: #fff;
}

.container {
  padding: 32rpx;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

button {
  background: none;
  padding: 0;
  margin: 0;
  line-height: inherit;
}

button::after {
  border: none;
}

button:focus {
  outline: none;
}

::-webkit-scrollbar {
  width: 0;
  height: 0;
  background: transparent;
}

.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(10, 22, 40, 0.8);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(245, 198, 108, 0.3);
  border-top-color: #f5c66c;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #8b9bb4;
}

.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 32rpx;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.error-title {
  font-size: 32rpx;
  color: #fff;
  margin-bottom: 16rpx;
}

.error-message {
  font-size: 26rpx;
  color: #8b9bb4;
  text-align: center;
  margin-bottom: 32rpx;
}

.error-btn {
  background: linear-gradient(135deg, #f5c66c 0%, #e8a84a 100%);
  color: #0a1628;
  font-size: 28rpx;
  font-weight: 600;
  padding: 20rpx 48rpx;
  border-radius: 100rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #5a6a7a;
}